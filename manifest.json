{
  "manifest_version": 3,
  "name": "Tickr",
  "version": "1.0",
  "description": "Ticketmaster resale tracker",
  "permissions": ["storage"],
  "host_permissions": [
    "https://api.telegram.org/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "content_scripts": [
    {
      "matches": [
        "https://www.ticketmaster.co.uk/*",
        "https://www.ticketmaster.com/*",
        "https://www.ticketmaster.it/*"
      ]