{
  "manifest_version": 3,
  "name": "Tickr – Ticket Alert Bot",
  "version": "1.0",
  "description": "Automatically finds Ticketmaster resale tickets and alerts you instantly.",
  "permissions": [
    "storage"
  ],
  "host_permissions": [
    "https://api.telegram.org/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": [
  "https://www.ticketmaster.co.uk/*",
  "https://www.ticketmaster.com/*"
],
      "js": ["content.js"]
    }
  ],
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  }
}